@page "{id:int}"
@model NotesApp.Pages.Projects.DetailsModel

@{
    ViewData["Title"] = Model.Project.Name;
}

<h1>@Model.Project.Name</h1>

<div class="section-header">
    <h2>Tasks</h2>

    <button type="button"
            class="add-button"
            data-bs-toggle="modal"
            data-bs-target="#createTaskModal">
        +
    </button>
</div>

@if (Model.Project.Tasks.Count == 0)
{
    <p>No tasks yet.</p>
}
else
{
    <div class="task-grid">

        @foreach (var task in Model.Project.Tasks.Where(t => !t.IsComplete))
        {
            <div class="task-card">

                <form method="post"
                      asp-page-handler="ToggleTask"
                      asp-route-id="@Model.Project.Id"
                      asp-route-taskId="@task.Id"
                      class="task-complete">

                    <input type="checkbox"
                           onchange="this.form.submit()" />

                </form>


                <form method="post"
                      asp-page-handler="DeleteTask"
                      asp-route-id="@Model.Project.Id"
                      asp-route-taskId="@task.Id"
                      class="task-delete"
                      onsubmit="return confirm('Delete this task?');">

                    <button type="submit">
                        ×
                    </button>

                </form>


                <div class="task-content">

                    <div class="task-title">
                        @task.Title
                    </div>

                    <div class="task-description">
                        <!-- Description will go here later -->
                    </div>

                    <div class="task-tags">
                        <!-- Tags will go here later -->
                    </div>

                </div>

            </div>
        }

    </div>

    <details>
        <summary>
            Completed
            (@Model.Project.Tasks.Count(t => t.IsComplete))
        </summary>

        <div class="mt-2">
            <div class="task-grid">

                @foreach (var task in Model.Project.Tasks.Where(t => t.IsComplete))
                {
                    <div class="task-card completed">

                        <form method="post"
                              asp-page-handler="ToggleTask"
                              asp-route-id="@Model.Project.Id"
                              asp-route-taskId="@task.Id"
                              class="task-complete">

                            <input type="checkbox"
                                   checked
                                   onchange="this.form.submit()" />

                        </form>


                        <form method="post"
                              asp-page-handler="DeleteTask"
                              asp-route-id="@Model.Project.Id"
                              asp-route-taskId="@task.Id"
                              class="task-delete"
                              onsubmit="return confirm('Delete this task?');">

                            <button type="submit">
                                ×
                            </button>

                        </form>


                        <div class="task-content">

                            <div class="task-title">
                                @task.Title
                            </div>

                            <div class="task-description">
                                <!-- Description will go here later -->
                            </div>

                            <div class="task-tags">
                                <!-- Tags will go here later -->
                            </div>

                        </div>

                    </div>
                }

            </div>
        </div>
    </details>
}

<div class="modal fade" id="createTaskModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <form method="post" asp-page-handler="CreateTask">

                <div class="modal-header">
                    <h5 class="modal-title">
                        Create Task
                    </h5>

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal">
                    </button>
                </div>

                <div class="modal-body">

                    <input type="hidden"
                           name="projectId"
                           value="@Model.Project.Id" />

                    <div class="mb-3">
                        <label class="form-label">
                            Task title
                        </label>

                        <input name="title"
                               class="form-control" />
                    </div>

                </div>

                <div class="modal-footer">

                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>

                    <button type="submit"
                            class="btn btn-primary">
                        Create
                    </button>

                </div>

            </form>

        </div>
    </div>
</div>

<form method="post" asp-page-handler="Delete" asp-route-id="@Model.Project.Id"
      onsubmit="return confirm('Are you sure you want to delete this project?');">

    <button type="submit" class="btn btn-danger">
        Delete Project
    </button>

</form>