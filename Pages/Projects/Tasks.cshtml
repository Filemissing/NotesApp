@page "{id:int}"
@model NotesApp.Pages.Projects.TasksModel
@Html.AntiForgeryToken()

<script>
    const projectId = @Model.Project.Id;
</script>

@{
    ViewData["Title"] = Model.Project.Name;
}

<partial name="_ProjectHeader" model="Model.Project" />

<div class="section-header">
    <h2>Tasks</h2>

    <button id="add-task-button"
            class="add-button">
        <i class="bi bi-plus"></i>
    </button>
</div>

@if (Model.Project.Tasks.Count == 0)
{
    <p>No tasks yet.</p>
}
else
{
    <div class="task-grid">

        @foreach (var task in Model.Project.Tasks.Where(t => !t.IsComplete))
        {
            <div class="task-card">

                <form method="post"
                      asp-page-handler="ToggleTask"
                      asp-route-id="@Model.Project.Id"
                      asp-route-taskId="@task.Id"
                      class="task-complete">

                    <input type="checkbox"
                           onchange="this.form.submit()" />

                </form>


                <button type="button"
                        class="task-edit-button"
                        data-bs-toggle="modal"
                        data-bs-target="#editTaskModal"
                        data-task-id="@task.Id"
                        data-task-title="@task.Title"
                        data-task-description="@task.Description"
                        data-task-tags="@string.Join(", ", task.Tags.Select(t => t.Name))">

                    <i class="bi bi-pencil"></i>

                </button>


                <form method="post"
                      asp-page-handler="DeleteTask"
                      asp-route-id="@Model.Project.Id"
                      asp-route-taskId="@task.Id"
                      class="task-delete"
                      onsubmit="return confirm('Delete this task?');">

                    <button type="submit">
                        <i class="bi bi-x"></i>
                    </button>

                </form>


                <div class="task-content">

                    <div class="task-title">
                        @task.Title
                    </div>

                    <div class="task-description">
                        @task.Description
                    </div>

                    <div class="task-tags">
                        @foreach (var tag in task.Tags)
                        {
                            <span class="tag">
                                @tag.Name
                            </span>
                        }
                    </div>

                </div>

            </div>
        }

    </div>

    <details>
        <summary>
            Completed
            (@Model.Project.Tasks.Count(t => t.IsComplete))
        </summary>

        <div class="mt-2">
            <div class="task-grid">

                @foreach (var task in Model.Project.Tasks.Where(t => t.IsComplete))
                {
                    <div class="task-card completed">

                        <form method="post"
                              asp-page-handler="ToggleTask"
                              asp-route-id="@Model.Project.Id"
                              asp-route-taskId="@task.Id"
                              class="task-complete">

                            <input type="checkbox"
                                   checked
                                   onchange="this.form.submit()" />

                        </form>


                        <button type="button"
                                class="task-edit-button"
                                data-bs-toggle="modal"
                                data-bs-target="#editTaskModal"
                                data-task-id="@task.Id"
                                data-task-title="@task.Title"
                                data-task-description="@task.Description"
                                data-task-tags="@string.Join(", ", task.Tags.Select(t => t.Name))">

                            <i class="bi bi-pencil"></i>

                        </button>


                        <form method="post"
                              asp-page-handler="DeleteTask"
                              asp-route-id="@Model.Project.Id"
                              asp-route-taskId="@task.Id"
                              class="task-delete"
                              onsubmit="return confirm('Delete this task?');">

                            <button type="submit">
                                ×
                            </button>

                        </form>


                        <div class="task-content">

                            <div class="task-title">
                                @task.Title
                            </div>

                            <div class="task-description">
                                @task.Description
                            </div>

                            <div class="task-tags">
                                @foreach (var tag in task.Tags)
                                {
                                    <span class="tag">
                                        @tag.Name
                                    </span>
                                }
                            </div>

                        </div>

                    </div>
                }

            </div>
        </div>
    </details>
}


<footer class="border-top footer text-muted">
    <form method="post" asp-page-handler="Delete" asp-route-id="@Model.Project.Id"
          onsubmit="return confirm('Are you sure you want to delete this project?');">
        <button type="submit" class="btn btn-danger">
            Delete Project
        </button>
    </form>
</footer>

<div class="modal fade" id="editTaskModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <form method="post" asp-page-handler="EditTask">

                <div class="modal-header">

                    <h5 class="modal-title">
                        Edit Task
                    </h5>

                </div>


                <div class="modal-body">

                    <input type="hidden"
                           id="edit-task-id"
                           name="taskId" />

                    <input type="hidden"
                           name="projectId"
                           value="@Model.Project.Id" />


                    <div class="mb-3">

                        <label class="form-label">
                            Task title
                        </label>

                        <input id="edit-task-title"
                               class="form-control"
                               name="title" />

                    </div>


                    <div class="mb-3">

                        <label class="form-label">
                            Description
                        </label>

                        <textarea id="edit-task-description"
                                  class="form-control"
                                  name="description"
                                  rows="4"></textarea>

                    </div>

                    <div class="mb-3">

                        <label class="form-label">
                            Tags
                        </label>

                        <input id="edit-task-tags"
                               class="form-control"
                               name="tags"
                               placeholder="school, important, portfolio" />

                    </div>

                </div>


                <div class="modal-footer">

                    <button type="button"
                            class="btn btn-secondary"
                            id="cancel-edit-task">
                        Cancel
                    </button>

                    <button type="submit"
                            class="btn btn-primary">
                        Save
                    </button>

                </div>

            </form>

        </div>
    </div>
</div>

<div class="modal fade" id="renameProjectModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <form method="post" asp-page-handler="RenameProject">

                <div class="modal-header">
                    <h5 class="modal-title">
                        Rename Project
                    </h5>

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal">
                    </button>
                </div>

                <div class="modal-body">

                    <input type="hidden"
                           name="projectId"
                           value="@Model.Project.Id" />

                    <div class="mb-3">

                        <label class="form-label">
                            Project name
                        </label>

                        <input class="form-control"
                               name="name"
                               value="@Model.Project.Name" />

                    </div>

                </div>

                <div class="modal-footer">

                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>

                    <button type="submit"
                            class="btn btn-primary">
                        Save
                    </button>

                </div>

            </form>

        </div>
    </div>
</div>

